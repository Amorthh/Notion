<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>mood tracker</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #191919;
    --card: #202020;
    --card-hover: #272727;
    --border: rgba(255, 255, 255, 0.09);
    --border-soft: rgba(255, 255, 255, 0.055);
    --text-primary: #ededed;
    --text-muted: #9b9b9b;
    --text-faint: #6f6f6f;
    --accent: #c98a5e;

    --m1: #7d4256;
    --m1-soft: rgba(125, 66, 86, 0.35);
    --m2: #9b5a45;
    --m2-soft: rgba(155, 90, 69, 0.35);
    --m3: #b3924f;
    --m3-soft: rgba(179, 146, 79, 0.35);
    --m4: #7f9a68;
    --m4-soft: rgba(127, 154, 104, 0.35);
    --m5: #4b9b81;
    --m5-soft: rgba(75, 155, 129, 0.35);
  }

  html, body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    width: 100%;
    min-height: 100%;
  }

  body {
    display: flex;
    justify-content: center;
    padding: 28px 16px;
  }

  .app {
    width: 100%;
    max-width: 420px;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 2px;
  }

  .title {
    font-family: 'Fraunces', serif;
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 18px;
  }

  /* mood wave — signature element */
  .wave-wrap {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px 10px;
    margin-bottom: 16px;
  }
  .wave-label {
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  #wave-svg { display: block; width: 100%; height: 46px; }

  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 14px;
  }

  .nav button#prev-month,
  .nav button#next-month {
    flex-shrink: 0;
  }

  .nav-center {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .nav button {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    width: 30px;
    height: 30px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .nav button:hover { background: var(--card-hover); color: var(--text-primary); border-color: var(--border-soft); }
  .nav button:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }

  .month-label {
    font-family: 'Fraunces', serif;
    font-size: 17px;
    font-weight: 500;
    white-space: nowrap;
  }

  .today-btn {
    display: inline-block;
    width: max-content !important;
    max-width: none;
    white-space: nowrap;
    appearance: none !important;
    -webkit-appearance: none !important;
    background: transparent !important;
    border: none !important;
    outline: none;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 5px auto 0;
    color: var(--text-faint);
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    line-height: 1.3;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .today-btn:hover { color: var(--accent); }
  .today-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    margin-bottom: 6px;
  }
  .weekdays span {
    text-align: center;
    font-size: 10.5px;
    letter-spacing: 0.05em;
    color: var(--text-faint);
    text-transform: uppercase;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 5px;
  }

  .cell {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 9px;
    border: 1px solid var(--border-soft);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12.5px;
    color: var(--text-muted);
    cursor: pointer;
    transition: transform 0.12s ease, filter 0.12s ease;
  }
  .cell:hover { transform: scale(1.06); }
  .cell:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .cell.empty-cell { visibility: hidden; cursor: default; }

  .cell.has-mood { color: rgba(20, 15, 12, 0.78); font-weight: 600; border: none; }
  .cell.today { box-shadow: inset 0 0 0 1.5px var(--text-primary); }
  .cell.has-mood.today { box-shadow: inset 0 0 0 1.5px rgba(255,255,255,0.55); }

  .cell.mood-1 { background: var(--m1); }
  .cell.mood-2 { background: var(--m2); }
  .cell.mood-3 { background: var(--m3); }
  .cell.mood-4 { background: var(--m4); }
  .cell.mood-5 { background: var(--m5); }

  .legend {
    display: flex;
    justify-content: space-between;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .legend-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
  }
  .legend-dot {
    width: 12px;
    height: 12px;
    border-radius: 4px;
  }
  .legend-item span {
    font-size: 10px;
    color: var(--text-faint);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 12px;
  }
  .stat {
    background: rgba(255,255,255,0.02);
    border-radius: 10px;
    padding: 10px 8px;
    text-align: center;
  }
  .stat-num {
    font-family: 'Fraunces', serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-primary);
  }
  .stat-label {
    font-size: 9.5px;
    color: var(--text-faint);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* popover */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 7, 12, 0.55);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10;
    padding: 20px;
  }
  .overlay.open { display: flex; }

  .popover {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
    width: 100%;
    max-width: 260px;
  }
  .popover-date {
    font-family: 'Fraunces', serif;
    font-size: 15px;
    margin-bottom: 12px;
  }
  .mood-options { display: flex; flex-direction: column; gap: 6px; }
  .mood-option {
    display: flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 8px 10px;
    cursor: pointer;
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    text-align: left;
    transition: background 0.15s, border-color 0.15s;
  }
  .mood-option:hover { background: var(--card-hover); }
  .mood-option:focus-visible { outline: 2px solid var(--accent); }
  .mood-swatch { width: 14px; height: 14px; border-radius: 4px; flex-shrink: 0; }

  .clear-btn {
    margin-top: 8px;
    width: 100%;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 8px;
    color: var(--text-faint);
    font-size: 12px;
    cursor: pointer;
  }
  .clear-btn:hover { color: var(--text-muted); background: var(--card-hover); }

  .save-note {
    text-align: center;
    font-size: 10.5px;
    color: var(--text-faint);
    margin-top: 14px;
    min-height: 14px;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .save-note.show { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .cell, .nav button { transition: none; }
  }
</style>
</head>
<body>

<div class="app">
  <div class="title">mood tracker</div>

  <div class="wave-wrap">
    <div class="wave-label">last 30 days</div>
    <svg id="wave-svg" viewBox="0 0 380 46" preserveAspectRatio="none"></svg>
  </div>

  <div class="card">
    <div class="nav">
      <button id="prev-month" aria-label="Previous month">‹</button>
      <div class="nav-center">
        <div class="month-label" id="month-label">July 2026</div>
        <button class="today-btn" id="today-btn">jump to today</button>
      </div>
      <button id="next-month" aria-label="Next month">›</button>
    </div>

    <div class="weekdays">
      <span>S</span><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span>
    </div>

    <div class="grid" id="grid"></div>

    <div class="legend" id="legend"></div>

    <div class="stats" id="stats"></div>

    <div class="save-note" id="save-note">saved</div>
  </div>
</div>

<div class="overlay" id="overlay">
  <div class="popover">
    <div class="popover-date" id="popover-date">July 19</div>
    <div class="mood-options" id="mood-options"></div>
    <button class="clear-btn" id="clear-btn">clear entry</button>
  </div>
</div>

<script>
(function () {
  var MOODS = [
    { value: 1, label: 'awful', color: 'var(--m1)' },
    { value: 2, label: 'bad', color: 'var(--m2)' },
    { value: 3, label: 'okay', color: 'var(--m3)' },
    { value: 4, label: 'fine', color: 'var(--m4)' },
    { value: 5, label: 'great', color: 'var(--m5)' }
  ];
  var MOOD_HEX = { 1: '#7d4256', 2: '#9b5a45', 3: '#b3924f', 4: '#7f9a68', 5: '#4b9b81' };

  var today = new Date();
  var viewYear = today.getFullYear();
  var viewMonth = today.getMonth();
  var data = {};
  var activeDateKey = null;
  var STORAGE_KEY = 'relationship-moods';

  function pad(n) { return n < 10 ? '0' + n : '' + n; }
  function dateKey(y, m, d) { return y + '-' + pad(m + 1) + '-' + pad(d); }
  function todayKey() { return dateKey(today.getFullYear(), today.getMonth(), today.getDate()); }

  async function storageGet(key) {
    if (window.storage && typeof window.storage.get === 'function') {
      try {
        var res = await window.storage.get(key, false);
        return res ? res.value : null;
      } catch (e) {
        return null;
      }
    }
    try { return localStorage.getItem(key); } catch (e) { return null; }
  }

  async function storageSet(key, valueStr) {
    if (window.storage && typeof window.storage.set === 'function') {
      try {
        await window.storage.set(key, valueStr, false);
        return;
      } catch (e) {}
    }
    try { localStorage.setItem(key, valueStr); } catch (e) {}
  }

  async function loadData() {
    try {
      var value = await storageGet(STORAGE_KEY);
      if (value) data = JSON.parse(value);
    } catch (e) {
      data = {};
    }
    render();
  }

  async function saveData() {
    await storageSet(STORAGE_KEY, JSON.stringify(data));
    var note = document.getElementById('save-note');
    note.classList.add('show');
    setTimeout(function () { note.classList.remove('show'); }, 1200);
  }

  function renderMonthLabel() {
    var names = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    document.getElementById('month-label').textContent = names[viewMonth] + ' ' + viewYear;
  }

  function renderGrid() {
    var grid = document.getElementById('grid');
    grid.innerHTML = '';
    var firstDay = new Date(viewYear, viewMonth, 1).getDay();
    var daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
    var tKey = todayKey();

    for (var i = 0; i < firstDay; i++) {
      var empty = document.createElement('div');
      empty.className = 'cell empty-cell';
      grid.appendChild(empty);
    }

    for (var d = 1; d <= daysInMonth; d++) {
      var key = dateKey(viewYear, viewMonth, d);
      var cell = document.createElement('button');
      cell.className = 'cell';
      cell.type = 'button';
      cell.textContent = d;
      cell.setAttribute('aria-label', 'Log mood for ' + key);

      if (data[key]) cell.classList.add('has-mood', 'mood-' + data[key]);
      if (key === tKey) cell.classList.add('today');

      cell.addEventListener('click', function () {
        openPopover(this.getAttribute('data-key'));
      });
      cell.setAttribute('data-key', key);

      grid.appendChild(cell);
    }
  }

  function renderLegend() {
    var legend = document.getElementById('legend');
    legend.innerHTML = '';
    MOODS.forEach(function (m) {
      var item = document.createElement('div');
      item.className = 'legend-item';
      item.innerHTML = '<div class="legend-dot" style="background:' + m.color + '"></div><span>' + m.label + '</span>';
      legend.appendChild(item);
    });
  }

  function renderStats() {
    var stats = document.getElementById('stats');
    var daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
    var entries = [];
    for (var d = 1; d <= daysInMonth; d++) {
      var key = dateKey(viewYear, viewMonth, d);
      if (data[key]) entries.push(data[key]);
    }
    var avg = entries.length ? (entries.reduce(function (a, b) { return a + b; }, 0) / entries.length) : null;
    var avgLabel = avg === null ? '—' : MOODS[Math.round(avg) - 1].label;

    var streak = 0;
    var cursor = new Date();
    while (true) {
      var k = dateKey(cursor.getFullYear(), cursor.getMonth(), cursor.getDate());
      if (data[k]) { streak++; cursor.setDate(cursor.getDate() - 1); }
      else break;
    }

    stats.innerHTML =
      '<div class="stat"><div class="stat-num">' + entries.length + '</div><div class="stat-label">logged</div></div>' +
      '<div class="stat"><div class="stat-num">' + avgLabel + '</div><div class="stat-label">avg mood</div></div>' +
      '<div class="stat"><div class="stat-num">' + streak + '</div><div class="stat-label">day streak</div></div>';
  }

  function renderWave() {
    var svg = document.getElementById('wave-svg');
    var points = [];
    var cursor = new Date(today);
    cursor.setDate(cursor.getDate() - 29);

    var w = 380, h = 46, step = w / 29;
    var i = 0;
    var coords = [];
    while (i <= 29) {
      var key = dateKey(cursor.getFullYear(), cursor.getMonth(), cursor.getDate());
      if (data[key]) {
        var val = data[key];
        var y = h - 6 - ((val - 1) / 4) * (h - 14);
        coords.push({ x: i * step, y: y, val: val });
      }
      cursor.setDate(cursor.getDate() + 1);
      i++;
    }

    var svgContent = '';
    if (coords.length > 1) {
      var pathD = 'M ' + coords.map(function (c) { return c.x.toFixed(1) + ' ' + c.y.toFixed(1); }).join(' L ');
      svgContent += '<path d="' + pathD + '" fill="none" stroke="#c98a5e" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>';
    }
    coords.forEach(function (c) {
      svgContent += '<circle cx="' + c.x.toFixed(1) + '" cy="' + c.y.toFixed(1) + '" r="3" fill="' + MOOD_HEX[c.val] + '"/>';
    });
    if (coords.length === 0) {
      svgContent = '<text x="190" y="27" text-anchor="middle" fill="#6c6178" font-size="11" font-family="Inter, sans-serif">no entries yet</text>';
    }
    svg.innerHTML = svgContent;
  }

  function render() {
    renderMonthLabel();
    renderGrid();
    renderLegend();
    renderStats();
    renderWave();
  }

  function openPopover(key) {
    activeDateKey = key;
    var parts = key.split('-');
    var dt = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
    var names = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    document.getElementById('popover-date').textContent = names[dt.getMonth()] + ' ' + dt.getDate() + ', ' + dt.getFullYear();

    var optionsEl = document.getElementById('mood-options');
    optionsEl.innerHTML = '';
    MOODS.forEach(function (m) {
      var btn = document.createElement('button');
      btn.className = 'mood-option';
      btn.type = 'button';
      btn.innerHTML = '<span class="mood-swatch" style="background:' + m.color + '"></span>' + m.label;
      btn.addEventListener('click', function () {
        data[activeDateKey] = m.value;
        saveData();
        render();
        closePopover();
      });
      optionsEl.appendChild(btn);
    });

    document.getElementById('overlay').classList.add('open');
  }

  function closePopover() {
    document.getElementById('overlay').classList.remove('open');
    activeDateKey = null;
  }

  document.getElementById('overlay').addEventListener('click', function (e) {
    if (e.target === this) closePopover();
  });

  document.getElementById('clear-btn').addEventListener('click', function () {
    if (activeDateKey) {
      delete data[activeDateKey];
      saveData();
      render();
    }
    closePopover();
  });

  document.getElementById('prev-month').addEventListener('click', function () {
    viewMonth--;
    if (viewMonth < 0) { viewMonth = 11; viewYear--; }
    render();
  });

  document.getElementById('next-month').addEventListener('click', function () {
    viewMonth++;
    if (viewMonth > 11) { viewMonth = 0; viewYear++; }
    render();
  });

  document.getElementById('today-btn').addEventListener('click', function () {
    viewYear = today.getFullYear();
    viewMonth = today.getMonth();
    render();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closePopover();
  });

  loadData();
})();
</script>

</body>
</html>
